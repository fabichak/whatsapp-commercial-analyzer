# Anthropic paid API key. Required for `--llm-mode api` or `hybrid` fallback.
ANTHROPIC_API_KEY=

# Max-subscription OAuth (Agent SDK) is alternative/complement: run `claude login`
# to create an OAuth session file. Then use `--llm-mode max` or `hybrid`.
# No env var needed for Max path — session file read by claude-agent-sdk.

# Optional: API-path budget cap in USD. Max path (flat subscription) not gated.
LLM_BUDGET_USD=10

# --- Stage 4 / MAX tuning ---
# Use bundled claude CLI one-shot (-p) instead of SDK stream-json. Required on
# WSL2 where stream-json stdin transport hangs.
CLAUDE_MAX_ONESHOT=1
# Per-call CLI timeout (seconds).
CLAUDE_MAX_TIMEOUT_S=180
# Kill stray `claude` processes before each CLI spawn. WILL kill parent
# Claude Code session. Use only for batch runs.
CLAUDE_MAX_KILL_OTHERS=0
# Parallel LLM calls in stage 4.
STAGE4_CONCURRENCY=5
# Templates bundled per LLM call (1 = spec-literal, higher = fewer calls).
STAGE4_TEMPLATE_BATCH_SIZE=10
# verify_stage4_max: cap templates at this count (0 = all).
STAGE4_VERIFY_TEMPLATE_LIMIT=50
